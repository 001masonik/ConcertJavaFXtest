<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.concertjavafx.gui.LoginFrame">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Вхід у застосунок" />
    <TextField fx:id="loginField" maxWidth="250" promptText="Логін" />
    <PasswordField fx:id="passwordField" maxWidth="250" promptText="Пароль" />
    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#handleLogin" prefWidth="80" text="Увійти" />
        <Button onAction="#handleOpenRegister" prefWidth="100" text="Реєстрація" />
    </HBox>
</VBox>
