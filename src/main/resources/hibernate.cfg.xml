<!DOCTYPE hibernate-configuration PUBLIC "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:./concert_db;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>
        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hbm2ddl.auto">update</property>
        <property name="show_sql">true</property>

        <mapping class="org.example.concertjavafx.entity.User"/>
        <mapping class="org.example.concertjavafx.entity.Song"/>
        <mapping class="org.example.concertjavafx.entity.Vote"/>
        <mapping class="org.example.concertjavafx.entity.Config"/>
    </session-factory>
</hibernate-configuration>